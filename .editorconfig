# EditorConfig — https://editorconfig.org/
# Forces consistent indentation, encoding, and line endings across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown often relies on trailing whitespace for line breaks.
[*.md]
trim_trailing_whitespace = false

# Makefiles require literal tabs.
[Makefile]
indent_style = tab
