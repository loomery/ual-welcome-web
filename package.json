{
  "name": "ual-welcome-week-next",
  "version": "0.1.0",
  "private": true,
  "description": "UAL Welcome Week beta — Next.js + JS + Tailwind. Mobile-first, WCAG 2.2 AA, UAL Design System compliant.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,json,css}\"",
    "audit": "npm audit --audit-level=high --omit=dev",
    "audit:full": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm run audit && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@serwist/next": "^9.5.9",
    "clsx": "^2.1.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serwist": "^9.5.9",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4"
  }
}
